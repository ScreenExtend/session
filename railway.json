{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "cargo build --release --locked"
  },
  "deploy": {
    "startCommand": "./target/release/session-backend-rust",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "numReplicas": 1,
    "sleepApplication": false,
    "runtime": "V2",
    "multiRegionConfig": {
      "us-west2": {
        "numReplicas": 1
      }
    },
    "limitOverride": {
      "containers": {
        "cpu": 8,
        "memoryBytes": 8000000000,
        "diskBytes": 5000000000
      }
    }
  }
}
